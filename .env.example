# Backend API base URL
# Local dev: http://localhost:3000
# Production: https://api.slbbc.in
VITE_API_BASE_URL=http://localhost:3000

# Use mock backend for local dev without real backend
VITE_USE_MOCK_API=true

# Sentry error tracking (optional, leave empty for dev)
VITE_SENTRY_DSN=

# App version (auto-injected during build, this is fallback)
VITE_APP_VERSION=0.1.0
